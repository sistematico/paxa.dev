[Unit]
Description=Paxá Next.js Application
After=network.target

[Service]
Type=simple
User=nginx
WorkingDirectory=/var/www/paxa.dev
ExecStart=/home/nginx/.bun/bin/bun run start
Restart=always
RestartSec=5s
StartLimitBurst=5

# Segurança (ajustado para permitir home)
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
