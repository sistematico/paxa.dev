{
  "name": "paxa.dev",
  "version": "0.4.0",
  "description": "A monorepo template built with Bun, Hono, Vite, and React",
  "author": "Steve Simkins",
  "license": "MIT",
  "homepage": "https://github.com/stevedylandev/bhvr",
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "./server",
    "./client",
    "./shared"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=client",
    "dev:server": "turbo dev --filter=server",
    "build": "turbo build",
    "build:client": "turbo build --filter=client",
    "build:server": "turbo build --filter=server",
    "build:single": "NODE_OPTIONS='--max-old-space-size=768' BUN_JSC_forceRAMSize=524288000 /home/nginx/.bun/bin/bun run build && /home/nginx/.bun/bin/bun run copy:static && BUN_JSC_forceRAMSize=524288000 /home/nginx/.bun/bin/bun run build:server",
    "copy:static": "rm -rf server/static && cp -r client/dist server/static",
    "start:single": "cd server && NODE_ENV=production PORT=8082 /home/nginx/.bun/bin/bun run dist/index.js",
    "push": "cd server && bunx drizzle-kit push",
    "lint": "biome lint .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=shared --filter=server",
    "format": "biome --css-parse-tailwind-directives=true format . --write"
  },
  "keywords": [
    "bun",
    "hono",
    "react",
    "vite",
    "monorepo",
    "turbo"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/nodemailer": "^7.0.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "bun-types": "latest",
    "turbo": "^2.6.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.552.0",
    "nodemailer": "^7.0.10",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^15.18.0"
  }
}
