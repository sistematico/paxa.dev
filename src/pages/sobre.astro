---
// import aboutImg from "@/assets/about-astro.png";
import PageLayout from "@/layouts/Base.astro";
// import { Image } from "astro:assets";

const meta = {
	description: "Sobre o profissional",
	title: "Sobre",
};
---

<PageLayout meta={meta}>
	<div class="space-y-6">
		<h1 class="title">Sobre</h1>
		<p>
			Em breve...
		</p>
		<!-- <div class="flex justify-center">
			<Image alt="A cartoon cactus looking at the 'Astro.build' logo"	fetchpriority="high" loading="eager" src={aboutImg} />
		</div> -->
		<p>Algumas coisas que posso fazer por você:</p>
		<ul class="list-inside list-disc">
			<li>Site seu ou da sua empresa</li>
			<li>Sistemas</li>
			<li>Identidade visual</li>
		</ul>
		<p>
			Clone ou crie um fork do meu <a
				aria-label="github repository"
				class="cactus-link inline-block"
				href="https://github.com/sistematico/paxa.dev"
				rel="noopener noreferrer"
				target="_blank">repositório</a>
		</p>
	</div>
</PageLayout>
