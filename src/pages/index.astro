---
import FullLayout from '../layouts/FullLayout.astro';
---

<FullLayout>
  <div class="relative grid h-full place-items-center sm:grid-cols-2">
    <h2 class="flex flex-col items-center gap-2 self-end sm:gap-4 sm:self-auto sm:justify-self-end">
      <div class="gradient-text text-center font-extrabold tracking-tighter text-8xl">Paxá</div>
    </h2>
    <div id="astronaut" class="w-2/3 max-w-3xl self-start sm:w-10/12 sm:self-auto sm:justify-self-start">
      <img class="h-full w-full object-cover" src="/img/paxa.svg" alt="" />
    </div>
  </div>
</FullLayout>