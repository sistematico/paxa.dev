---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort((a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());
---

<MainLayout>
	<h1 class="text-3xl my-2">Postagens</h1>	
	{
		posts.map((post) => (
			<a href={`/blog/${post.slug}/`}>
				<div class="max-w-md mx-auto bg-white rounded-xl shadow-md overflow-hidden md:max-w-2xl m-3">
					<div class="p-4 flex items-center">
						<div class="pr-4 bg-blue-500 p-2 rounded-lg text-center">
							<FormattedDate date={post.data.publishDate} />
							{/* <p class="text-4xl font-bold text-white px-0">18th</p>} */}
							{/* <p class="text-sm text-white px-0">November, 2023</p> */}
						</div>
						<div class="ml-4">
							<div class="uppercase tracking-wide text-sm text-indigo-500 font-semibold">{post.data.title}</div>
							{/* <p class="mt-2 text-gray-500">{post.data.description}</p> */}
						</div>
					</div>
				</div>
			</a>
		))
	}
</MainLayout>

